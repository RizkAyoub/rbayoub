---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../i18n/index';

const lang = 'en';
const t = getContent(lang);
const p = t.work;
const meta = t.meta.work;
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} currentPage="work">
  <div class="section" aria-labelledby="work-headline">
    <div class="container">

      <header class="page-header">
        <p class="eyebrow">{p.eyebrow}</p>
        <h1 id="work-headline" class="page-headline font-display">{p.headline}</h1>
        <p class="page-intro">{p.intro}</p>
      </header>

      <hr class="rule" />

      <div class="engagements">
        {p.engagements.map((eng) => (
          <article class="engagement" aria-labelledby={`eng-${eng.id}`}>
            <div class="eng-meta">
              <span class="eyebrow eng-id">{eng.id}</span>
              <span class="eng-sector eyebrow">{eng.sector}</span>
            </div>

            <div class="eng-content">
              <h2 id={`eng-${eng.id}`} class="eng-title font-display">{eng.title}</h2>

              <dl class="eng-details">
                <div class="eng-row">
                  <dt>{p.labels.context}</dt>
                  <dd>{eng.context}</dd>
                </div>
                <div class="eng-row">
                  <dt>{p.labels.role}</dt>
                  <dd>{eng.role}</dd>
                </div>
                <div class="eng-row">
                  <dt>{p.labels.outcome}</dt>
                  <dd>{eng.outcome}</dd>
                </div>
              </dl>
            </div>
          </article>
        ))}
      </div>

      <hr class="rule" />

      <div class="work-cta">
        <a href={`/${lang}/contact`} class="btn btn-primary">{t.home.cta1}</a>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding-block: 4rem 3.5rem;
    max-width: 640px;
  }

  .eyebrow {
    display: block;
    margin-bottom: 1.25rem;
  }

  .page-headline {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
  }

  .page-intro {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-muted);
    max-width: 60ch;
    margin: 0;
  }

  /* ── Engagements ── */
  .engagement {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0 4rem;
    padding-block: 3.5rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .engagement:last-child { border-bottom: none; }

  .eng-meta {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 0.25em;
  }

  .eng-id { margin-bottom: 0; }

  .eng-sector {
    color: var(--color-accent);
    margin-bottom: 0;
    line-height: 1.4;
  }

  .eng-title {
    font-size: clamp(1.375rem, 2.2vw, 1.875rem);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin: 0 0 2rem;
    color: var(--color-ink);
    line-height: 1.2;
  }

  .eng-details {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .eng-row {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 0 2rem;
    padding-block: 1.125rem;
    border-bottom: 1px solid var(--color-border);
  }

  .eng-row:first-child {
    border-top: 1px solid var(--color-border);
  }

  .eng-row dt {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding-top: 0.2em;
    flex-shrink: 0;
  }

  .eng-row dd {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-muted);
    margin: 0;
    max-width: 62ch;
  }

  /* ── CTA ── */
  .work-cta {
    padding-block: 3rem 2rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: 2px;
    transition: all 0.18s ease;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-accent);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .engagement {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .eng-meta {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .eng-row {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .eng-row dt {
      margin-bottom: 0.125rem;
    }
  }
</style>
