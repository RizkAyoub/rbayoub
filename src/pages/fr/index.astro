---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getContent } from '../../i18n/index';

const lang = 'fr';
const t = getContent(lang);
const p = t.home;
const meta = t.meta.home;
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} currentPage="">
  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="hero section" aria-labelledby="hero-headline">
    <div class="container">
      <div class="hero-inner">
        <p class="eyebrow hero-eyebrow">{p.eyebrow}</p>

        <h1 id="hero-headline" class="hero-headline font-display">
          {p.headline.split('\n').map((line: string, i: number) => (
            <span class="headline-line">{line}{i === 0 && <br />}</span>
          ))}
        </h1>

        <p class="hero-paragraph">{p.paragraph}</p>
        <p class="hero-secondary">{p.secondaryParagraph}</p>

        <div class="hero-ctas">
          <a href={`/${lang}/contact`} class="btn btn-primary">{p.cta1}</a>
          <a href={`/${lang}/services`} class="btn btn-ghost">{p.cta2}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Credibility strip ─────────────────────────────────── -->
  <div class="credibility-strip" aria-label="Domaines de pratique">
    <div class="container">
      <hr class="rule" />
      <ul class="strip-list" role="list">
        {p.credibilityStrip.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
      <hr class="rule" />
    </div>
  </div>

  <!-- ── What we do ───────────────────────────────────────── -->
  <section class="section what-we-do" aria-labelledby="services-headline">
    <div class="container">
      <div class="section-header">
        <h2 id="services-headline" class="section-title font-display">{p.whatWeDoTitle}</h2>
      </div>

      <div class="services-rows">
        {p.services.map((svc) => (
          <div class="service-row">
            <div class="svc-left">
              <span class="svc-number eyebrow">{svc.id}</span>
              <h3 class="svc-title">{svc.title}</h3>
            </div>
            <p class="svc-desc">{svc.description}</p>
          </div>
        ))}
      </div>

      <div class="services-link-row">
        <a href={`/${lang}/services`} class="text-link">{p.viewAllServices} →</a>
      </div>
    </div>
  </section>

  <!-- ── When to engage ───────────────────────────────────── -->
  <section class="section when-section" aria-labelledby="when-headline">
    <div class="container">
      <div class="when-inner">
        <div class="when-label">
          <h2 id="when-headline" class="when-title font-display">{p.whenTitle}</h2>
        </div>
        <ul class="when-list" role="list">
          {p.whenItems.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ── Method teaser ────────────────────────────────────── -->
  <section class="section method-teaser" aria-labelledby="method-teaser-headline">
    <div class="container">
      <hr class="rule" />
      <div class="teaser-inner">
        <div class="teaser-label">
          <p class="eyebrow">{p.methodTeaserTitle}</p>
        </div>
        <div class="teaser-body">
          <p class="teaser-text">{p.methodTeaser}</p>
          <a href={`/${lang}/method`} class="text-link">{p.methodLink} →</a>
        </div>
      </div>
      <hr class="rule" />
    </div>
  </section>

  <!-- ── Final CTA ─────────────────────────────────────────── -->
  <section class="section final-cta" aria-label="Appel à l'action">
    <div class="container">
      <div class="cta-inner">
        <a href={`/${lang}/contact`} class="btn btn-primary">{p.ctaFinal}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block-start: 7rem;
    padding-block-end: 5rem;
  }

  .hero-inner {
    max-width: 820px;
  }

  .hero-eyebrow {
    margin-bottom: 2rem;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 300;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin: 0 0 2rem;
  }

  .headline-line {
    display: inline;
  }

  .hero-paragraph {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ink);
    max-width: 60ch;
    margin: 0 0 1.5rem;
  }

  .hero-secondary {
    font-size: 0.875rem;
    line-height: 1.8;
    color: var(--color-muted);
    max-width: 60ch;
    margin: 0 0 3rem;
    border-top: 1px solid var(--color-border);
    padding-top: 1rem;
  }

  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-decoration: none;
    padding: 0.75rem 1.75rem;
    border-radius: 2px;
    transition: all 0.18s ease;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border: 1px solid var(--color-accent);
  }

  .btn-primary:hover {
    background: transparent;
    color: var(--color-accent);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-ink);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-ink);
  }

  .credibility-strip {
    padding-block: 0.5rem;
  }

  .strip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2.5rem;
    list-style: none;
    margin: 0;
    padding: 1.25rem 0;
  }

  .strip-list li {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .section-header {
    margin-bottom: 3.5rem;
    max-width: 56ch;
  }

  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 300;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
  }

  .services-rows {
    border-top: 1px solid var(--color-border);
  }

  .service-row {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0 3rem;
    padding-block: 2.25rem;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .svc-left {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .svc-number {
    display: block;
    margin-bottom: 0;
  }

  .svc-title {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .svc-desc {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-muted);
    margin: 0;
    max-width: 58ch;
    padding-top: 0.15em;
  }

  .services-link-row {
    padding-block: 2rem 0;
  }

  .when-section {
    background: var(--color-surface);
    padding-block: 5rem;
  }

  .when-inner {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0 4rem;
    align-items: start;
  }

  .when-title {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 300;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin: 0;
  }

  .when-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .when-list li {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted);
    padding-block: 0.875rem;
    border-bottom: 1px solid var(--color-border);
    padding-left: 1.25rem;
    position: relative;
  }

  .when-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    top: 1.05rem;
  }

  .when-list li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .method-teaser {
    padding-block: 5rem;
  }

  .teaser-inner {
    display: grid;
    grid-template-columns: 14rem 1fr;
    gap: 0 4rem;
    padding-block: 2.5rem;
  }

  .teaser-label {
    padding-top: 0.15em;
  }

  .teaser-text {
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin: 0 0 1.5rem;
    max-width: 58ch;
  }

  .text-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    transition: opacity 0.18s;
  }

  .text-link:hover { opacity: 0.7; }

  .final-cta {
    padding-block: 5rem 7rem;
  }

  .cta-inner {
    display: flex;
    align-items: center;
  }

  @media (max-width: 900px) {
    .service-row {
      grid-template-columns: 10rem 1fr;
      gap: 0 2rem;
    }

    .when-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .teaser-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .hero { padding-block-start: 4rem; }

    .service-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .svc-left {
      flex-direction: row;
      align-items: baseline;
      gap: 1rem;
    }
  }
</style>
